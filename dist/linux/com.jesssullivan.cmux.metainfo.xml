<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.jesssullivan.cmux</id>

  <name>cmux</name>
  <summary>Terminal multiplexer with split panes, workspaces, and WebAuthn</summary>

  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      cmux is a GTK4 terminal multiplexer built on libghostty, providing
      tabbed workspaces, split pane management, a sidebar for workspace
      navigation, and session persistence.
    </p>
    <p>
      Features include a JSON-RPC socket control interface, hot-reloadable
      configuration, and integrated FIDO2/WebAuthn support via zig-ctap2
      for hardware security key authentication directly in the terminal.
    </p>
  </description>

  <launchable type="desktop-id">com.jesssullivan.cmux.desktop</launchable>

